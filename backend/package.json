{
  "name": "storiesofus-backend",
  "version": "1.0.0",
  "description": "Backend API for StoriesOfUs - Social issue storytelling platform",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "build:frontend": "cd ../frontend && npm install && npm run build",
    "copy:build": "mkdir -p public && cp -r ../frontend/build/. public/",
    "setup": "npm run build:frontend && npm run copy:build",
    "start:prod": "npm run setup && node server.js"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^8.0.3",
    "multer": "^2.0.2",
    "socket.io": "^4.8.3"
  },
  "devDependencies": {
    "nodemon": "^3.0.2"
  }
}
